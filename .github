name: Deploy Vite App to Pages

on:
  push:
    branches: ["main"]

  # Erlaubt es, den Deploy manuell im GitHub Actions Tab zu starten
  workflow_dispatch:

# Setzt die nötigen Rechte für das GitHub-Token
permissions:
  contents: read
  pages: write
  id-token: write

# Verhindert, dass mehrere Deploys gleichzeitig laufen
concurrency:
  group: "pages"
  cancel-in-progress: true

jobs:
  deploy:
    environment:
      name: github-pages
      url: ${{ steps.deployment.outputs.page_url }}
    runs-on: ubuntu-latest
    steps:
      - name: Checkout Code
        uses: actions/checkout@v4

      - name: Setup Node.js
        uses: actions/actions-setup-node@v4
        with:
          node-version: 20
          cache: "npm"

      - name: Install dependencies
        run: npm ci

      - name: Build Project
        run: npm run build

      - name: Setup Pages
        uses: actions/configure-pages@v4

      - name: Upload Build Artifact
        uses: actions/upload-pages-artifact@v3
        with:
          path: "./dist"

      - name: Deploy to GitHub Pages
        id: deployment
        uses: actions/deploy-pages@v4
